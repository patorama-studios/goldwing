# Goldwing website environment template — copy to `.env` and fill in.
#
# The `.env` file lives at the hosting account root (same level as public_html/,
# NEVER inside public_html/). The live server's real values are held in the
# committee password manager — see HANDOVER.md.
#
# Loaded by app/Services/Env.php at the top of app/bootstrap.php.
# A local override file `.env.local` is also read (used for local development).

# --- Database (cPanel → MySQL Databases) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# --- Application ---
# Canonical site URL, no trailing slash.
APP_BASE_URL=https://goldwing.org.au

# Master encryption key. Encrypts the secrets stored in the database
# (Stripe keys, SMTP password) via app/Services/EncryptionService.php.
# Generate once for a NEW install:  php -r "echo bin2hex(random_bytes(32));"
# NEVER change or lose this on a live site — every stored secret becomes
# unreadable and would need to be re-entered through Admin → Settings.
APP_KEY=

# --- Integrations (most third-party keys are managed in Admin → Settings,
#     stored encrypted in the database; these are the env-level ones) ---
# Google Maps Places key for address autocomplete on signup/profile forms.
GOOGLE_MAPS_API_KEY=
# AI page builder provider (kie.ai).
KIE_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6

# --- Social login (optional; leave blank unless configured) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY_PATH=
APPLE_OAUTH_REDIRECT_URI=
